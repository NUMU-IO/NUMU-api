# Environment
DEBUG=true
APP_NAME=Octyrafiy API
API_VERSION=1.0.0

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/octyrafiy

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT (RS256)
# Generate keys with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_ALGORITHM=RS256
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nyour-private-key-here\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nyour-public-key-here\n-----END PUBLIC KEY-----"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3030","http://localhost:8000"]

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Tap Payments
TAP_SECRET_KEY=sk_test_your_tap_secret_key

# Shippo
SHIPPO_API_KEY=shippo_test_your_shippo_api_key

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4

# Resend Email
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@octyrafiy.com

# Cloudflare R2
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=octyrafiy-assets
R2_PUBLIC_URL=https://assets.octyrafiy.com
