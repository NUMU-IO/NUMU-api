# =============================================================================
# NUMU API - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# Environment
DEBUG=true
ENVIRONMENT=development  # development, staging, production
APP_NAME=NUMU API
APP_VERSION=0.1.0

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=numu

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT (RS256 asymmetric signing)
# Generate keys with: python scripts/generate_jwt_keys.py
JWT_ALGORITHM=RS256
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Session (for admin panel cookies)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET_KEY=your-32-char-minimum-secret-key-here

# Credential Encryption
# Used to encrypt merchant payment gateway credentials at rest (AES via Fernet)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# MUST be at least 32 characters
CREDENTIAL_ENCRYPTION_KEY=your-credential-encryption-key-minimum-32-chars

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3030","http://localhost:8000"]

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_AUTH_REQUESTS_PER_MINUTE=5

# =============================================================================
# Shopify App Integration
# =============================================================================

# Shared secret between this API and the numu-payments-intelligence Shopify app.
# Must match NUMU_API_INTERNAL_KEY in numu-payments-intelligence/.env
NUMU_API_INTERNAL_KEY=your-internal-key-here

# =============================================================================
# Payment Gateways
# =============================================================================

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Tap Payments
TAP_SECRET_KEY=sk_test_your_tap_secret_key
TAP_PUBLISHABLE_KEY=pk_test_your_tap_publishable_key

# =============================================================================
# External Services
# =============================================================================

# Shippo
SHIPPO_API_KEY=shippo_test_your_shippo_api_key

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o

# Resend Email
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM_ADDRESS=noreply@numu.com
EMAIL_FROM_NAME=NUMU

# MinIO / S3-compatible Object Storage
# For local dev with MinIO: S3_ENDPOINT_URL=http://localhost:9000
# For production with R2: S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=numu
S3_PUBLIC_URL=http://localhost:9000/numu
S3_REGION=us-east-1

# Database Backups
R2_BACKUP_BUCKET_NAME=numu-db-backups
BACKUP_RETENTION_DAYS=30

# =============================================================================
# Egyptian Market Integrations
# =============================================================================

# Paymob (Egyptian Payment Gateway)
PAYMOB_API_KEY=your_paymob_api_key
PAYMOB_INTEGRATION_ID=your_card_integration_id
PAYMOB_IFRAME_ID=your_iframe_id
PAYMOB_HMAC_SECRET=your_hmac_secret
PAYMOB_WALLET_INTEGRATION_ID=your_wallet_integration_id

# Fawry (Retail Pay Points)
FAWRY_MERCHANT_CODE=your_merchant_code
FAWRY_SECURITY_KEY=your_security_key
FAWRY_BASE_URL=https://atfawry.fawrystaging.com

# Bosta Shipping (Egyptian Courier)
BOSTA_API_KEY=your_bosta_api_key
BOSTA_BUSINESS_ID=your_business_id
BOSTA_BASE_URL=https://app.bosta.co/api/v2
BOSTA_WEBHOOK_SECRET=your_webhook_secret

# Cash on Delivery
COD_ENABLED=true
COD_FEE_PERCENTAGE=0.0
COD_FEE_FLAT=0
COD_MAX_AMOUNT=1000000
COD_MIN_AMOUNT=0

# WhatsApp Business API
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_verify_token
WHATSAPP_APP_SECRET=your_app_secret
WHATSAPP_ENABLED=false

# Egyptian Tax Authority (ETA) E-Invoicing
ETA_CLIENT_ID=your_client_id
ETA_CLIENT_SECRET=your_client_secret
ETA_BASE_URL=https://api.invoicing.eta.gov.eg/api/v1
ETA_TOKEN_URL=https://id.eta.gov.eg/connect/token
ETA_ACTIVITY_CODE=4649
ETA_ENABLED=false

# =============================================================================
# Observability (Sentry, Structured Logging)
# =============================================================================

# Sentry - Error tracking and performance monitoring
# Get your DSN from https://sentry.io -> Project Settings -> Client Keys
# Leave empty to disable Sentry
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_SEND_DEFAULT_PII=false

# Structured Logging
# LOG_LEVEL: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_FORMAT: "json" for production, "console" for development
LOG_LEVEL=INFO
LOG_FORMAT=console

# =============================================================================
# Localization
# =============================================================================
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=["en", "ar"]
