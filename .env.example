# Environment
ENVIRONMENT=development
DEBUG=true
APP_NAME=NUMU API
APP_VERSION=1.0.0

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=numu

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT (MUST be at least 32 characters)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=dev-jwt-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Session (MUST be at least 32 characters, separate from JWT)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET_KEY=dev-session-secret-key-change-in-prod-min-32-chars

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_AUTH_REQUESTS_PER_MINUTE=5

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Tap Payments
TAP_SECRET_KEY=sk_test_your_tap_secret_key
TAP_PUBLISHABLE_KEY=pk_test_your_tap_publishable_key

# Shippo
SHIPPO_API_KEY=shippo_test_your_shippo_api_key

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview

# Resend Email
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM_ADDRESS=noreply@numu.com
EMAIL_FROM_NAME=NUMU

# Cloudflare R2
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=numu-assets
R2_PUBLIC_URL=https://assets.numu.com
