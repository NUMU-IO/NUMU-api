# =============================================================================
# NUMU API - Staging Environment Configuration
# =============================================================================
# Copy this file to .env.staging and fill in your actual values.
# NEVER commit .env.staging — it is gitignored.

# Application
DEBUG=false
ENVIRONMENT=staging
APP_NAME=NUMU API
APP_VERSION=0.1.0

# Database (PostgreSQL 15+)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=numu
POSTGRES_PASSWORD=<STAGING_DB_PASSWORD>
POSTGRES_DB=numu_staging

# Connection Pool (tune based on staging load)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Redis
REDIS_HOST=redis-master
REDIS_PORT=6379
REDIS_PASSWORD=<STAGING_REDIS_PASSWORD>
REDIS_DB=0

# JWT (RS256 asymmetric signing)
# Generate keys with: python scripts/generate_jwt_keys.py
JWT_ALGORITHM=RS256
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n<YOUR_PRIVATE_KEY>\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n<YOUR_PUBLIC_KEY>\n-----END PUBLIC KEY-----"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Session (for admin panel cookies)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET_KEY=<GENERATE_A_32_CHAR_MIN_SECRET>

# API Documentation auth (staging only)
DOCS_USERNAME=staging-admin
DOCS_PASSWORD=<STAGING_DOCS_PASSWORD>

# CORS — origins allowed to call this API from a browser
# Staging API sits behind nginx on port 8080.
# Add every URL a browser will load the frontend from.
CORS_ORIGINS=["http://188.166.156.151:8080","http://188.166.156.151:3000","http://188.166.156.151:3030","http://localhost:3000","http://localhost:3030"]

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_AUTH_REQUESTS_PER_MINUTE=5

# =============================================================================
# Payment Gateways
# =============================================================================

# Stripe (test/sandbox keys)
STRIPE_SECRET_KEY=sk_test_<YOUR_STRIPE_TEST_KEY>
STRIPE_PUBLISHABLE_KEY=pk_test_<YOUR_STRIPE_TEST_KEY>
STRIPE_WEBHOOK_SECRET=whsec_<YOUR_STRIPE_WEBHOOK_SECRET>

# Tap Payments (sandbox)
TAP_SECRET_KEY=sk_test_<YOUR_TAP_TEST_KEY>
TAP_PUBLISHABLE_KEY=pk_test_<YOUR_TAP_TEST_KEY>

# Paymob (sandbox)
PAYMOB_API_KEY=<PAYMOB_SANDBOX_API_KEY>
PAYMOB_INTEGRATION_ID=<PAYMOB_SANDBOX_CARD_INTEGRATION_ID>
PAYMOB_IFRAME_ID=<PAYMOB_SANDBOX_IFRAME_ID>
PAYMOB_HMAC_SECRET=<PAYMOB_SANDBOX_HMAC_SECRET>
PAYMOB_WALLET_INTEGRATION_ID=<PAYMOB_SANDBOX_WALLET_INTEGRATION_ID>

# Fawry (staging/sandbox)
FAWRY_MERCHANT_CODE=<FAWRY_SANDBOX_MERCHANT_CODE>
FAWRY_SECURITY_KEY=<FAWRY_SANDBOX_SECURITY_KEY>
FAWRY_BASE_URL=https://atfawry.fawrystaging.com

# Cash on Delivery
COD_ENABLED=true
COD_FEE_PERCENTAGE=0.0
COD_FEE_FLAT=0
COD_MAX_AMOUNT=1000000
COD_MIN_AMOUNT=0

# =============================================================================
# External Services
# =============================================================================

# Shippo (test)
SHIPPO_API_KEY=shippo_test_<YOUR_SHIPPO_TEST_KEY>

# OpenAI
OPENAI_API_KEY=sk-<YOUR_OPENAI_API_KEY>
OPENAI_MODEL=gpt-4o

# Resend Email
RESEND_API_KEY=re_<YOUR_RESEND_API_KEY>
EMAIL_FROM_ADDRESS=noreply@staging.numu.com
EMAIL_FROM_NAME=NUMU Staging

# MinIO / S3-compatible Object Storage
# For MinIO: endpoint is http://minio:9000 (internal Docker network)
# For R2: endpoint is https://<account_id>.r2.cloudflarestorage.com
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=<MINIO_ROOT_PASSWORD>
S3_BUCKET_NAME=numu
S3_PUBLIC_URL=https://dev-api.yourdomain.com/uploads
S3_REGION=us-east-1

# MinIO credentials (used by docker-compose)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=<GENERATE_A_STRONG_PASSWORD>

# Database Backups
R2_BACKUP_BUCKET_NAME=numu-staging-db-backups
BACKUP_RETENTION_DAYS=14

# =============================================================================
# Egyptian Market Integrations
# =============================================================================

# Bosta Shipping (sandbox)
BOSTA_API_KEY=<BOSTA_SANDBOX_API_KEY>
BOSTA_BUSINESS_ID=<BOSTA_SANDBOX_BUSINESS_ID>
BOSTA_BASE_URL=https://app.bosta.co/api/v2
BOSTA_WEBHOOK_SECRET=<BOSTA_SANDBOX_WEBHOOK_SECRET>

# WhatsApp Business API (sandbox)
WHATSAPP_ACCESS_TOKEN=<WHATSAPP_SANDBOX_ACCESS_TOKEN>
WHATSAPP_PHONE_NUMBER_ID=<WHATSAPP_SANDBOX_PHONE_NUMBER_ID>
WHATSAPP_BUSINESS_ACCOUNT_ID=<WHATSAPP_SANDBOX_BUSINESS_ACCOUNT_ID>
WHATSAPP_WEBHOOK_VERIFY_TOKEN=<WHATSAPP_SANDBOX_VERIFY_TOKEN>
WHATSAPP_APP_SECRET=<WHATSAPP_SANDBOX_APP_SECRET>
WHATSAPP_ENABLED=false

# Egyptian Tax Authority (ETA) E-Invoicing (pre-production)
ETA_CLIENT_ID=<ETA_PREPROD_CLIENT_ID>
ETA_CLIENT_SECRET=<ETA_PREPROD_CLIENT_SECRET>
ETA_BASE_URL=https://api.preprod.invoicing.eta.gov.eg/api/v1
ETA_TOKEN_URL=https://id.preprod.eta.gov.eg/connect/token
ETA_ACTIVITY_CODE=4649
ETA_ENABLED=false

# =============================================================================
# Observability
# =============================================================================

# Sentry - Error tracking and performance monitoring (REQUIRED for staging)
SENTRY_DSN=<YOUR_SENTRY_DSN>
SENTRY_TRACES_SAMPLE_RATE=0.5
SENTRY_PROFILES_SAMPLE_RATE=0.5
SENTRY_SEND_DEFAULT_PII=false

# Structured Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# =============================================================================
# Slack Alerting
# =============================================================================

SLACK_ENABLED=false
SLACK_ENVIRONMENT=staging
SLACK_WEBHOOK_DEV=<SLACK_STAGING_WEBHOOK>
SLACK_FORCE_DEV_CHANNEL=true

# =============================================================================
# Localization
# =============================================================================
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=["en", "ar"]
