# =============================================================================
# NUMU API - Production Environment Configuration
# =============================================================================
# Copy to .env on the production server and fill in real values.
# NEVER commit this file with real secrets.
# NEVER set DEBUG=true in production.

# Application
DEBUG=false
ENVIRONMENT=production
APP_NAME=NUMU API
APP_VERSION=0.1.0

# Database (PostgreSQL 15+ — use a managed instance in production)
POSTGRES_HOST=<PROD_DB_HOST>
POSTGRES_PORT=5432
POSTGRES_USER=numu
POSTGRES_PASSWORD=<PROD_DB_PASSWORD>
POSTGRES_DB=numu

# Connection Pool (scale up for production traffic)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Redis (use a managed Redis instance with auth + TLS)
REDIS_HOST=<PROD_REDIS_HOST>
REDIS_PORT=6379
REDIS_PASSWORD=<PROD_REDIS_PASSWORD>
REDIS_DB=0

# JWT (RS256 — generate with: python scripts/generate_jwt_keys.py)
JWT_ALGORITHM=RS256
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n<YOUR_PRIVATE_KEY>\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n<YOUR_PUBLIC_KEY>\n-----END PUBLIC KEY-----"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Session (generate: python -c "import secrets; print(secrets.token_urlsafe(32))")
SESSION_SECRET_KEY=<GENERATE_A_32_CHAR_MIN_SECRET>
SECURE_COOKIES=true
SAMESITE_COOKIES=lax
COOKIE_DOMAIN=numu.com

# CORS — origins allowed to call this API from a browser.
# Use your real domain once DNS is configured. Until then use the droplet IP.
CORS_ORIGINS=["http://188.166.156.151","https://188.166.156.151","http://188.166.156.151:3000","http://188.166.156.151:3030"]

# Allowed hosts
ALLOWED_HOSTS=["numu.com","api.numu.com","merchant.numu.com"]

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_ANON_REQUESTS_PER_MINUTE=60
RATE_LIMIT_AUTH_REQUESTS_PER_MINUTE=5
RATE_LIMIT_CHECKOUT_REQUESTS_PER_MINUTE=10

# API Docs — leave empty to disable docs in production
DOCS_USERNAME=
DOCS_PASSWORD=

# =============================================================================
# Payment Gateways (PRODUCTION credentials — handle with care)
# =============================================================================

# Paymob (live keys)
PAYMOB_API_KEY=<PAYMOB_LIVE_API_KEY>
PAYMOB_INTEGRATION_ID=<PAYMOB_LIVE_CARD_INTEGRATION_ID>
PAYMOB_IFRAME_ID=<PAYMOB_LIVE_IFRAME_ID>
PAYMOB_HMAC_SECRET=<PAYMOB_LIVE_HMAC_SECRET>
PAYMOB_WALLET_INTEGRATION_ID=<PAYMOB_LIVE_WALLET_INTEGRATION_ID>

# Fawry (production)
FAWRY_MERCHANT_CODE=<FAWRY_LIVE_MERCHANT_CODE>
FAWRY_SECURITY_KEY=<FAWRY_LIVE_SECURITY_KEY>
FAWRY_BASE_URL=https://www.atfawry.com

# Cash on Delivery
COD_ENABLED=true
COD_FEE_PERCENTAGE=0.0
COD_FEE_FLAT=0
COD_MAX_AMOUNT=1000000
COD_MIN_AMOUNT=0

# =============================================================================
# External Services
# =============================================================================

# OpenAI
OPENAI_API_KEY=sk-<YOUR_OPENAI_API_KEY>
OPENAI_MODEL=gpt-4o

# Resend Email (production domain)
RESEND_API_KEY=re_<YOUR_RESEND_API_KEY>
EMAIL_FROM_ADDRESS=noreply@numu.com
EMAIL_FROM_NAME=NUMU

# Cloudflare R2 Object Storage (production bucket)
S3_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=<R2_ACCESS_KEY_ID>
S3_SECRET_ACCESS_KEY=<R2_SECRET_ACCESS_KEY>
S3_BUCKET_NAME=numu-production
S3_PUBLIC_URL=https://assets.numu.com
S3_REGION=auto

# Database Backups (separate bucket)
R2_BACKUP_BUCKET_NAME=numu-db-backups
BACKUP_RETENTION_DAYS=30

# =============================================================================
# Egyptian Market Integrations
# =============================================================================

# Bosta Shipping (production)
BOSTA_API_KEY=<BOSTA_LIVE_API_KEY>
BOSTA_BUSINESS_ID=<BOSTA_LIVE_BUSINESS_ID>
BOSTA_BASE_URL=https://app.bosta.co/api/v2
BOSTA_WEBHOOK_SECRET=<BOSTA_LIVE_WEBHOOK_SECRET>

# WhatsApp Business API (production)
WHATSAPP_ACCESS_TOKEN=<WHATSAPP_LIVE_ACCESS_TOKEN>
WHATSAPP_PHONE_NUMBER_ID=<WHATSAPP_LIVE_PHONE_NUMBER_ID>
WHATSAPP_BUSINESS_ACCOUNT_ID=<WHATSAPP_LIVE_BUSINESS_ACCOUNT_ID>
WHATSAPP_WEBHOOK_VERIFY_TOKEN=<WHATSAPP_LIVE_VERIFY_TOKEN>
WHATSAPP_APP_SECRET=<WHATSAPP_LIVE_APP_SECRET>
WHATSAPP_ENABLED=true

# Egyptian Tax Authority (ETA) E-Invoicing
ETA_CLIENT_ID=<ETA_LIVE_CLIENT_ID>
ETA_CLIENT_SECRET=<ETA_LIVE_CLIENT_SECRET>
ETA_BASE_URL=https://api.invoicing.eta.gov.eg/api/v1
ETA_TOKEN_URL=https://id.eta.gov.eg/connect/token
ETA_ACTIVITY_CODE=4649
ETA_ENABLED=true

# =============================================================================
# Observability (all required in production)
# =============================================================================

# Sentry — REQUIRED in production
SENTRY_DSN=<YOUR_SENTRY_DSN>
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_SEND_DEFAULT_PII=false

# Structured Logging — always JSON in production
LOG_LEVEL=WARNING
LOG_FORMAT=json

# =============================================================================
# Slack Alerting (configure all channels)
# =============================================================================

SLACK_ENABLED=true
SLACK_ENVIRONMENT=production
SLACK_FORCE_DEV_CHANNEL=false

SLACK_WEBHOOK_CRITICAL=<SLACK_CRITICAL_WEBHOOK>
SLACK_WEBHOOK_PAYMENTS=<SLACK_PAYMENTS_WEBHOOK>
SLACK_WEBHOOK_FRAUD=<SLACK_FRAUD_WEBHOOK>
SLACK_WEBHOOK_SHIPPING=<SLACK_SHIPPING_WEBHOOK>
SLACK_WEBHOOK_INFRA=<SLACK_INFRA_WEBHOOK>
SLACK_WEBHOOK_BUSINESS=<SLACK_BUSINESS_WEBHOOK>
SLACK_WEBHOOK_DEV=<SLACK_DEV_WEBHOOK>

SLACK_BOT_TOKEN=<SLACK_BOT_TOKEN>
SLACK_USER_ONCALL=<SLACK_USER_ID_ONCALL>
SLACK_USER_FRAUD_LEAD=<SLACK_USER_ID_FRAUD_LEAD>
SLACK_USER_INFRA_LEAD=<SLACK_USER_ID_INFRA_LEAD>
SLACK_USER_PAYMENTS_LEAD=<SLACK_USER_ID_PAYMENTS_LEAD>

# =============================================================================
# Localization
# =============================================================================
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=["en", "ar"]
