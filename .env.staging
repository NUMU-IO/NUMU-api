# =============================================================================
# NUMU API - Staging Environment Configuration
# =============================================================================
# IMPORTANT: Copy this file and fill in actual values before deployment
# DO NOT commit secrets to version control

# Environment
DEBUG=false
ENVIRONMENT=staging
APP_NAME=NUMU API
APP_VERSION=0.1.0

# Database (PostgreSQL)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=numu
POSTGRES_PASSWORD=CHANGE_ME_STAGING_DB_PASSWORD
POSTGRES_DB=numu_staging

# Redis
REDIS_HOST=redis-master
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_STAGING_REDIS_PASSWORD
REDIS_DB=0

# JWT (RS256 asymmetric signing)
# Generate keys with: python scripts/generate_jwt_keys.py
JWT_ALGORITHM=RS256
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Session (for admin panel cookies)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET_KEY=CHANGE_ME_STAGING_SESSION_SECRET_32_CHARS_MIN

# CORS - Update with your staging domain
CORS_ORIGINS=["https://staging.numu.com","https://dashboard.staging.numu.com"]

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_AUTH_REQUESTS_PER_MINUTE=5

# =============================================================================
# Payment Gateways
# =============================================================================

# Stripe (use test keys for staging)
STRIPE_SECRET_KEY=sk_test_your_stripe_test_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_test_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Tap Payments (use test keys for staging)
TAP_SECRET_KEY=sk_test_your_tap_test_key
TAP_PUBLISHABLE_KEY=pk_test_your_tap_test_key

# =============================================================================
# External Services
# =============================================================================

# Shippo (use test API key)
SHIPPO_API_KEY=shippo_test_your_key

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview

# Resend Email
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM_ADDRESS=staging@numu.com
EMAIL_FROM_NAME=NUMU Staging

# Cloudflare R2 (use staging bucket)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=numu-staging-assets
R2_PUBLIC_URL=https://staging-assets.numu.com

# Database Backups
R2_BACKUP_BUCKET_NAME=numu-staging-backups
BACKUP_RETENTION_DAYS=14

# =============================================================================
# Egyptian Market Integrations (use staging/test credentials)
# =============================================================================

# Paymob (use staging credentials)
PAYMOB_API_KEY=your_paymob_staging_api_key
PAYMOB_INTEGRATION_ID=your_staging_integration_id
PAYMOB_IFRAME_ID=your_staging_iframe_id
PAYMOB_HMAC_SECRET=your_staging_hmac_secret
PAYMOB_WALLET_INTEGRATION_ID=your_staging_wallet_integration_id

# Fawry (use staging environment)
FAWRY_MERCHANT_CODE=your_staging_merchant_code
FAWRY_SECURITY_KEY=your_staging_security_key
FAWRY_BASE_URL=https://atfawry.fawrystaging.com

# Bosta Shipping (use staging API)
BOSTA_API_KEY=your_bosta_staging_api_key
BOSTA_BUSINESS_ID=your_staging_business_id
BOSTA_BASE_URL=https://app.bosta.co/api/v2
BOSTA_WEBHOOK_SECRET=your_staging_webhook_secret

# Cash on Delivery
COD_ENABLED=true
COD_FEE_PERCENTAGE=0.0
COD_FEE_FLAT=0
COD_MAX_AMOUNT=1000000
COD_MIN_AMOUNT=0

# WhatsApp Business API (staging)
WHATSAPP_ACCESS_TOKEN=your_staging_access_token
WHATSAPP_PHONE_NUMBER_ID=your_staging_phone_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_staging_account_id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_staging_verify_token
WHATSAPP_APP_SECRET=your_staging_app_secret
WHATSAPP_ENABLED=false

# Egyptian Tax Authority - DISABLED in staging
ETA_ENABLED=false

# =============================================================================
# Observability
# =============================================================================

# Sentry - Error tracking and performance monitoring
SENTRY_DSN=https://your-staging-dsn@sentry.io/project-id
SENTRY_TRACES_SAMPLE_RATE=0.5
SENTRY_PROFILES_SAMPLE_RATE=0.5
SENTRY_SEND_DEFAULT_PII=false

# Structured Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# =============================================================================
# Localization
# =============================================================================
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=["en", "ar"]
